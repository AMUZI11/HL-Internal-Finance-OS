// HL Manager Pro — Prisma Schema
// Sesuai petunjuk.md Bagian 8 — Database Schema
// Engine: PostgreSQL via Supabase

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["queryCompiler", "driverAdapters"]
}

datasource db {
  provider = "postgresql"
}


// ─── PRODUCT CATEGORIES ────────────────────────────────────────────────────

model ProductCategory {
  id         String   @id @default(uuid())
  code       String   @unique @db.VarChar(50)
  name       String   @db.VarChar(100)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ─── USERS ─────────────────────────────────────────────────────────────────

model User {
  id             String            @id @default(uuid())
  username       String            @unique @db.VarChar(50)
  password_hash  String            @db.VarChar(255)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  tutorial_progress TutorialProgress?
}

// ─── TUTORIAL PROGRESS ─────────────────────────────────────────────────────

model TutorialProgress {
  id                    String   @id @default(uuid())
  user_id               String   @unique
  onboarding_completed  Boolean  @default(false)
  onboarding_last_step  Int      @default(0)
  tutorials_completed   String[] @default([])
  tutorials_in_progress Json     @default("[]")
  last_updated          DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])
}

// ─── CUSTOMERS ─────────────────────────────────────────────────────────────

model Customer {
  id              String    @id @default(uuid())
  nama            String    @db.VarChar(100)
  bonus_threshold BigInt    @default(0)
  is_deleted      Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  discounts    CustomerDiscount[]
  transactions Transaction[]
  bonus_grants BonusGrant[]
}

// ─── CUSTOMER DISCOUNTS ─────────────────────────────────────────────────────

model CustomerDiscount {
  id           String   @id @default(uuid())
  customer_id  String
  product_type String   @db.VarChar(50) // category code, e.g. 'LM', 'BR', or custom
  step_order   Int
  percentage   Decimal  @db.Decimal(5, 2)
  created_at   DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@unique([customer_id, product_type, step_order])
}

// ─── PRODUCTS ───────────────────────────────────────────────────────────────

model Product {
  id           String   @id @default(uuid())
  nama         String   @db.VarChar(100)
  harga_modal  BigInt   @default(0)
  harga_base   BigInt   @default(0)
  tipe         String   @db.VarChar(50) // category code, e.g. 'LM', 'BR', or custom
  is_deleted   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  transaction_items TransactionItem[]
}

// ─── TRANSACTIONS ───────────────────────────────────────────────────────────

model Transaction {
  id            String    @id @default(uuid())
  nomor_bon     String    @unique @db.VarChar(50)
  tanggal       DateTime  @db.Date
  customer_id   String?
  ongkir        BigInt    @default(0)
  deskripsi     String?
  is_bonus      Boolean   @default(false)
  status        String    @default("Piutang") @db.VarChar(10) // 'Piutang' | 'Lunas'
  tanggal_lunas DateTime? @db.Date
  omzet_total   BigInt    @default(0) // cached computed
  laba_total    BigInt    @default(0) // cached computed
  amount_owed   BigInt    @default(0) // omzet_total + ongkir, cached
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  customer     Customer?        @relation(fields: [customer_id], references: [id])
  items        TransactionItem[]
  bonus_grants BonusGrant[]

  @@index([customer_id, status, tanggal])
  @@index([tanggal, status])
}

// ─── TRANSACTION ITEMS ──────────────────────────────────────────────────────

model TransactionItem {
  id                    String   @id @default(uuid())
  transaction_id        String
  product_id            String?
  quantity              Int
  product_type_snapshot String   @db.VarChar(50) // snapshot kategori saat transaksi dibuat
  harga_base_snapshot   BigInt   // snapshot harga saat transaksi dibuat
  harga_modal_snapshot  BigInt   // snapshot modal saat transaksi dibuat
  discounted_unit_price BigInt   // hasil kalkulasi cascading
  line_omzet            BigInt   // discounted_unit_price × quantity
  line_laba             BigInt   // (discounted - harga_modal) × quantity
  is_bonus_item         Boolean  @default(false)
  created_at            DateTime @default(now())

  transaction Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  product     Product?    @relation(fields: [product_id], references: [id])
}

// ─── BONUS GRANTS ───────────────────────────────────────────────────────────

model BonusGrant {
  id              String   @id @default(uuid())
  customer_id     String
  transaction_id  String
  bonuses_granted Int
  omzet_consumed  BigInt
  granted_at      DateTime @default(now())

  customer    Customer    @relation(fields: [customer_id], references: [id])
  transaction Transaction @relation(fields: [transaction_id], references: [id])

  @@index([customer_id, granted_at])
}
